	.else
	.string "{CIRCLE_3} Vali JÄRGMISED ANDMED, et kuvada\n"
	.string "   LINNAKAART koos elupaiga(de)ga.$"
	.endif

Help_Text_HowToUseHomePC::
	.string "{CIRCLE_1} Mine koduse arvuti juurde,\n"
	.string "   seejärel vajuta A.\n"
	.string "{CIRCLE_2} Arvuti lülitub sisse.\n"
	.string "{CIRCLE_3} Vali kas ESEMETE HOIUSTAMINE\n"
	.string "   või POSTKAST.$"

Help_Text_HowToUseItemStorage::
	.string "{CIRCLE_1} Vali VÕTA ESE VÄLJA, et\n"
	.string "   arvutis hoiustatud ese välja võtta.\n"
	.string "{CIRCLE_2} Vali HOIUSTA ESE, et panna\n"
	.string "   ese KOTIST oma arvutisse.$"

Help_Text_HowToUseWithdrawItem2::
	.string "{CIRCLE_1} Vali VÕTA ESE VÄLJA.\n"
	.string "{CIRCLE_2} Vali ese, mida välja võtta.\n"
	.string "{CIRCLE_3} Ese saab välja võetud ja\n"
	.string "   paigutatud KOTI ESEMETE taskusse.\n"
	.string "   Seda saab ka otse anda\n"
	.string "   POKéMONile hoidmiseks.$"

Help_Text_HowToUseDepositItem2::
	.string "{CIRCLE_1} Vali HOIUSTA ESE.\n"
	.string "{CIRCLE_2} Vali {PLUS} juhtkangiga KOTIS\n"
	.string "   olev ese, mida hoiustada.\n"
	.string "{CIRCLE_3} Kui KOTIS pole midagi,\n"
	.string "   ei saa seda käsku kasutada!$"

Help_Text_HowToUseMailbox2::
	.string "Kui POKéMONilt võetakse KIRI,\n"
