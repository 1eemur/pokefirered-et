Help_Text_HowToUseRun::
	.string "TREENIJA lahingust ei saa PÕGENEDA!\n"
	.string "{CIRCLE_1} Metsiku POKéMONi eest saab PÕGENEDA.\n"
	.string "{CIRCLE_2} Põgenemise võimalus suureneb,\n"
	.string "   kui su lahingus olev POKéMON on kiire.$"

Help_Text_HowToRegisterKeyItem::
	.string "Võtmeset saab koheseks kasutamiseks\n"
	.string "SELECT-nupuga REGISTREERIDA!\n"
	.string "{CIRCLE_1} Ava VÕTMEESEMETE tasku.\n"
	.string "{CIRCLE_2} Vali võtmese, seejärel vali\n"
	.string "   REGISTREERI.$"

Help_Text_HowToUseBall::
	.string "{CIRCLE_1} Vali, et visata erililine POKé-\n"
	.string "   PALL, mida kasutatakse ainult SAFARIALAL.\n"
	.string "Kui metsikud POKéMONid ilmuvad, visa\n"
	.string "rohkesti SAFARIPALLE, et neid püüda!$"

Help_Text_HowToUseBait::
	.string "{CIRCLE_1} Vali, et visata erilist toitu,\n"
	.string "   mida kasutatakse ainult SAFARIALAL.\n"
	.string "See on POKéMONide toit, mähitud\n"
	.string "palliks lihtsaks söömiseks. Kui SÖÖT on\n"
	.string "visatud, võib metsik POKéMON\n"
	.string "sellest köituda ega pruugi põgeneda!$"

Help_Text_HowToUseRock::
	.string "{CIRCLE_1} Vali, et visata SAFARIALAL\n"
	.string "   maas lebav kivi.\n"
	.string "POKéMONile kivi viskamine võib\n"
	.string "ta põgenema panna, kuid\n"
	.string "muutub kergemini püüdavaks!$"

Help_Text_HowToUseHallOfFame::
	.string "{CIRCLE_1} Vali arvutis KUULSUSTEHALL.\n"
	.string "{CIRCLE_2} KUULSUSTEHALLI sisenenud\n"
	.string "   POKéMONe saab uurida.$"

