Help_Text_DefineHP::
	.string "EL näitab POKéMONi elujõudu.\n"
	.string "Kui POKéMONi EL langeb nullini,\l"
	.string "minestub ta ja ei suuda võidelda.\l"
	.string "Seega on lahingu võti proovida\l"
	.string "vaenlase EL nullini viia.\l"
	.string "Kui su POKéMONid on vigastatud, taasta\l"
	.string "nende EL POKéMONi KESKUSES või esemete abil.$"

Help_Text_DefineEXP::
	.string "KOGEMUSEpunktid on lühend sõnadest\n"
	.string "kogemuspunktid. POKéMONid teenivad\l"
	.string "kogemuspunkte, osaledes võidetud lahingutes.\l"
	.string "Kui POKéMON kogub piisavalt\l"
	.string "kogemuspunkte, tõuseb tema tase. KOGEMUSEriba\l"
	.string "näitab kogunenud punkte.\l"
	.string "Taseme tõustes läheb see nulliks.$"

Help_Text_DefineMoves::
	.string "POKéMONid võivad õppida kuni neli erinevat\n"
	.string "liigutust. On palju liigutuste liike,\l"
	.string "sealhulgas rünnakud ja erimõjuga\l"
	.string "liigutused. Õpitavate liigutuste liigid\l"
	.string "erinevad iga POKéMONi puhul.\l"
	.string "Mõnda liigutust saab õppida\l"
	.string "esemetelt.$"

Help_Text_DefineAttack::
	.string "RÜNNAK näitab rünnakuoskuse jõudu.\n"
	.string "Mida kõrgem see näitaja, seda\l"
	.string "võimsam on liigutus.\l"
	.string "Seda rakendatakse järgmiste liigutuste\l"
	.string "tüüpide puhul: TAVALINE, MÜRK, MAA,\l"
	.string "LENDAV, PUTUKAS, VÕITLEJA, KIVI, VAIM,\l"
	.string "ja TERAS.$"

Help_Text_DefineDefense::
	.string "KAITSE näitab POKéMONi vastupidavust\n"
	.string "füüsiliste rünnakute vastu.\l"
	.string "Mida kõrgem see näitaja, seda vähem\l"
	.string "kahju saadakse vaenlase füüsilisest löögist.$"

Help_Text_DefineSpAtk::
	.string "ER. RÜNNAK (Eriline Rünnak) näitab\n"
	.string "erirünnaku liigutuse jõudu.\l"
	.string "Mida kõrgem see näitaja, seda võimsam\l"
	.string "on erirünnaku liigutus.\l"
	.string "Seda rakendatakse järgmiste liigutuste\l"
	.string "tüüpide puhul: TULI, VESI, ELEKTER, ROHI,\l"
	.string "JÄÄ, PSÜÜHiKA, DRAAKON ja PIME.$"

Help_Text_DefineSpDef::
	.string "ER. KAITSE (Eriline Kaitse) näitab\n"
	.string "POKéMONi vastupidavust\l"
	.string "erir ü n n a k u t e  vastu.\l"
	.string "Mida kõrgem see näitaja, seda vähem\l"
	.string "kahju saadakse vaenlase erir ü n n a k u s t.$"

Help_Text_DefineSpeed::
	.string "KIIRUS näitab POKéMONi osavust.\n"
	.string "Kui see näitaja ületab vaenlase oma\l"
	.string "lahingus, saab POKéMON liigutuse teha\l"
	.string "enne oma aeglasemat vastast.$"

Help_Text_DefineLevel::
	.string "Ts. (Tase) näitab POKéMONi kasvu\n"
	.string "ja tugevust.\l"
	.string "Üldiselt tõusevad POKéMONi\l"
	.string "taseme tõustes tema näitajad nagu\l"
	.string "EL, RÜNNAK ja KAITSE, muutes ta tugevamaks.\l"
	.string "POKéMONid võivad taseme tõustes\l"
	.string "uue liigutuse selgeks õppida.$"

Help_Text_DefineType::
	.string "POKéMONid ja liigutused liigitatakse\n"
	.string "tüübi järgi. Igal tüübil on eelised ja\l"
	.string "puudused teiste tüüpide vastu.\l"
	.string "Näiteks, nagu kivi-paber-käärid mängus,\l"
	.string "on VESI tüüp tugev TULE tüübi vastu\l"
	.string "ja nõrk ROHU tüübi vastu.$"

Help_Text_DefineOT::
	.string "AT tähistab Algset TREENIJAT,\n"
	.string "esimest TREENIJAT, kes valitud\l"
	.string "POKéMONi püüdis.\l"
	.string "Isegi kui POKéMON vahetatakse, jääb\l"
	.string "AT nimi muutumatus.$"

Help_Text_DefineItem::
	.string "Kõiki POKéMONe saab panna hoidma\n"
	.string "ühte eset. Mõnda eset kasutab\l"
	.string "POKéMON automaatselt teatud\l"
	.string "olukordades. Et POKéMON eset hoiaks,\l"
	.string "vali ese KOTIST ja ANNA see\l"
	.string "POKéMONile.$"

Help_Text_DefineAbility::
	.string "Kõigil POKéMONidel on eriline OSKUS.\n"
	.string "Neid oskuseid on palju erinevaid,\l"
	.string "mõned kasutatavad lahingus, mõned\l"
	.string "mujal. Oskused erinevad\l"
	.string "liigiti. Mõnel liigil võib olla\l"
	.string "rohkem kui ühte liiki oskus.$"

Help_Text_DefineMoney::
	.string "Iga kord, kui võidad TREENIJAGA\n"
	.string "lahingu, saad auhinnaraha.\l"
	.string "Kogu auhinnaraha, et saaksid\l"
	.string "POKéMONi POODIDES nautida!$"

Help_Text_DefineMoveType::
	.string "Liigutused liigitatakse samuti tüüpide järgi.\n"
	.string "Kui teatud tüüpi POKéMON kasutab\l"
	.string "sama tüüpi liigutust, suureneb\l"
	.string "liigutuse jõud. Kui liigutuse tüübil\l"
	.string "on eelise vastavus sihtmärgi vastu,\l"
	.string "suureneb ka selle tõhusus.$"

Help_Text_DefineNature::
	.string "Kõigil POKéMONidel on isikupära\n"
	.string "ehk ISELOOM. POKéMONi\l"
	.string "iseloom näib mõjutavat, kuidas\l"
	.string "POKéMON tasemeid tõustes kasvab.$"

Help_Text_DefineIDNo::
	.string "ID nr. on spetsiaalne number, mis\n"
	.string "on sinule kui TREENIJALE omistatud.\l"
	.string "Koos AT nimega kasutatakse ID nr-i\l"
	.string "algse TREENIJA täpseks tuvastamiseks.\l"
	.string "ID nr. ei muutu isegi siis, kui\l"
	.string "POKéMON vahetatakse.$"

Help_Text_DefinePP::
	.string "JP tähistab Jõupunkte.\n"
	.string "See näitab, mitu korda saab\l"
	.string "teatud liigutust lahingus kasutada.\l"
	.string "Nagu EL, saab JP-d taastada\l"
	.string "külastades POKéMONi KESKUST\l"
	.string "või kasutades teatud esemeid.$"

Help_Text_DefinePower::
	.string "JÕUD näitab rünnaku tugevust.\n"
	.string "Mida suurem see number, seda\l"
	.string "suurem kahju saab vaenlasele\l"
	.string "põhjustada!$"

Help_Text_DefineAccuracy::
	.string "TÄPSUS näitab liigutuse\n"
	.string "vaenlase tabamise tõenäosust.\l"
	.string "Mida suurem see number, seda\l"
	.string "tõenäolisemalt liigutus tabab.$"

Help_Text_DefineFNT::
	.string "MIN tähistab minestunud.\n"
	.string "POKéMON minestub, kui tema EL\l"
	.string "langeb nullini. Ta ei suuda\l"
	.string "lahingus osaleda.\l"
	.string "Taasta minestunud POKéMON POKéMONi\l"
	.string "KESKUSES või kasuta eset.$"

Help_Text_DefineItems::
	.string "Igas POKéMONi POES ostetavad\n"
	.string "tavalised esemed pannakse ESEMETE taskusse.\l"
	.string "Esemeid saab kasutada, POKéMONile\l"
	.string "hoidmiseks anda või prügikasti visata.$"

Help_Text_DefineKeyItems::
	.string "Olulised esemed, mida leiad või\n"
	.string "inimestelt saad, pannakse\l"
	.string "VÕTMEESEMETE taskusse.\l"
	.string "Võtmesemeid saab kasutada või registreerida\l"
	.string "SELECT-ga koheseks kasutamiseks. Pärast\l"
	.string "registreerimist saab eset kasutada\l"
	.string "ilma MENÜÜD ja KOTTI avamata.$"

Help_Text_DefinePokeBalls::
	.string "POKéPALLID, mida kasutatakse\n"
	.string "metsikute POKéMONide püüdmiseks,\l"
	.string "pannakse POKéPALLIDE taskusse.\l"
	.string "POKéPALLE saab osta POKéMONi POODIDEST.\l"
	.string "Neid saab kasutada, POKéMONile\l"
	.string "hoidmiseks anda või prügikasti visata.$"

Help_Text_DefinePokedex::
	.string "See näitab, mitu POKéMONi liiki\n"
	.string "oled püüdnud ja/või evolutsiooniga\l"
	.string "POKéDEXi täitnud.\l"
	.string "Püüa kõvasti kõiksuguseid\l"
	.string "POKéMONe!$"

Help_Text_DefinePlayTime::
	.string "See on kogu aeg, mille oled\n"
	.string "selle mängu mängimisele kulutanud.$"

Help_Text_DefineBadges::
	.string "POKéMONi LIIGA MÄRGID, mille\n"
	.string "oled võitnud, registreeritakse ja\l"
	.string "kuvatakse. Teeni MÄRKE, alistades\l"
	.string "SAALIÜ L E M A ID erinevates linnades.$"

Help_Text_DefineTextSpeed::
	.string "Saad reguleerida, kui kiiresti\n"
	.string "tekst kuvatakse. Vali üks: AEGLANE,\l"
	.string "KESKMINE või KIIRE.$"

Help_Text_DefineBattleScene::
	.string "Saad valida, kas lahinguanimatsioon\n"
	.string "on SEES või VÄLJAS.$"

Help_Text_DefineBattleStyle::
	.string "Saad valida, kas TREENIJA saab\n"
	.string "vahetada POKéMONi pärast seda,\l"
	.string "kui see on vaenlase minestanud.\l"
	.string "Sea VAHETA peale, kui soovid\l"
	.string "võimalust POKéMONi vahetada pärast\l"
	.string "vaenlase minestamist.$"

Help_Text_DefineSound::
	.string "Saad valida MONO ja\n"
	.string "STEREO heliväljundi vahel.$"

Help_Text_DefineButtonMode::
	.string "Sea ABI peale, et kuvada abi\n"
	.string "vajutades L- või R-nuppu.\l"
	.string "Sea LR peale, et lubada\l"
	.string "POKéDEXi lehtede ja KOTI TASKUTE\l"
	.string "vahetamine L- ja R-nupu abil.\l"
	.string "Sea L=A peale, et L-nupp\l"
	.string "töötaks samamoodi kui A-nupp.$"

Help_Text_DefineFrame::
	.string "Saad valida teatud menüüde ümber\n"
	.string "oleva raami kujunduse. Proovi järele\l"
	.string "ja vaata, mis meeldib.$"

Help_Text_DefineCancel2::
	.string "Sätted muudetakse punasega\n"
	.string "näidatud valikuteks ja naased\l"
	.string "MENÜÜSSE.$"

Help_Text_DefineTM::
	.string "TM (Tehniline Masin) on seade,\n"
	.string "mida kasutatakse POKéMONile\l"
	.string "liigutuse õpetamiseks.\l"
	.string "Neid on palju erinevaid liike.\l"
	.string "Liigutusi saab õpetada ainult neile\l"
	.string "POKéMONidele, kes suudavad neid kasutada.\l"
	.string "TM puruneb pärast ühekordset kasutamist.$"

Help_Text_DefineHM::
	.string "HM (Peidetud Masin) on seade,\n"
	.string "mida kasutatakse POKéMONile\l"
	.string "PEIDETUD liigutuse õpetamiseks.\l"
	.string "PEIDETUD liigutust saab õpetada ainult\l"
	.string "neile POKéMONidele, kes suudavad seda kasutada.\l"
	.string "Erinevalt TM-ist saab HM-i kasutada\l"
	.string "ikka ja jälle. PEIDETUD liigutust\l"
	.string "on POKéMONil raske unustada.$"

Help_Text_DefineHMMove::
	.string "PEIDETUD liigutused on eriti olulised\n"
	.string "su seiklusele. Sellise liigutuse\l"
	.string "kasutamiseks väljaspool lahingut ava\l"
	.string "POKéMONi MENÜÜ ja lase seda\l"
	.string "liigutust tundval POKéMONil seda kasutada.\l"
	.string "Minestunud POKéMON võib kasutada\l"
	.string "PEIDETUD liigutust väljaspool lahingut.$"

Help_Text_DefineEvolution::
	.string "POKéMONide seas on neid, kes teatud\n"
	.string "tasemetele jõudes läbivad suuri muutusi\l"
	.string "(evolutsiooni). Evolutsioon põhjustab\l"
	.string "POKéMONi kuju muutumist, nime vahetust\l"
	.string "ja võib-olla ka õpitavate liigutuste\l"
	.string "muutumist. Mõned POKéMONid arenevad\l"
	.string "muudel põhjustel peale taseme tõusmise.$"

Help_Text_DefineStatusProblem::
	.string "Staatusprobleemid on järgmised:\n"
	.string "Uni: Ei saa liigutusi kasutada.\l"
	.string "Mürk: Põhjustab pidevat ELi kaotust.\l"
	.string "Halvatus: Võib liigutuste kasutamist takistada.\l"
	.string "Põletus: ELi kadu ja vähendab RÜNNAKUT.\l"
	.string "Külmutus: Ei saa liigutusi kasutada.\l"
	.string "Neid saab ravida esemetega jne.$"

Help_Text_DefinePokemon::
	.string "POKéMON on nimi, mida kasutatakse\n"
	.string "imeliste olendite kirjeldamiseks,\l"
	.string "kes elavad kõigis selle maailma\l"
	.string "nurkades. Inimesed kasvatavad\l"
	.string "POKéMONe lemmikloomadena,\l"
	.string "kasutavad neid võitluseks jne.$"

Help_Text_DefineIDNo2::
	.string "ID nr. on spetsiaalne number, mis\n"
	.string "on sinule kui TREENIJALE omistatud.\l"
	.string "Koos AT nimega kasutatakse ID nr-i\l"
	.string "algse TREENIJA täpseks tuvastamiseks.\l"
	.string "ID nr. ei muutu isegi siis, kui\l"
	.string "POKéMON vahetatakse.$"

Help_Text_DefineMoney2::
	.string "Iga kord, kui võidad TREENIJAGA\n"
	.string "lahingu, saad auhinnaraha.\l"
	.string "Kogu auhinnaraha, et saaksid\l"
	.string "POKéMONi POODIDES nautida!$"

Help_Text_DefineBadges2::
	.string "See näitab POKéMONi LIIGA MÄRKIDE\n"
	.string "arvu, mille oled võitnud.\l"
	.string "Teeni MÄRKE, alistades SAALIÜLEMAID\l"
	.string "erinevates linnades.$"

