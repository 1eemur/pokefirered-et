Help_Text_HowToUsePokedex::
	.string "{CIRCLE_1} Vali MENÜÜST POKéDEX.\n"
	.string "{CIRCLE_2} Vali POKéMONe käskudega nagu\n"
	.string "   POKéMONIDE NIMEKIRI,\n"
	.string "   POKéMONIDE ELUPAIGAD ja\n"
	.string "   OTSING.\n"
	.string "{CIRCLE_3} Vali POKéMON üksikasjaliku\n"
	.string "   teabe saamiseks.$"

Help_Text_HowToUsePokemon::
	.string "{CIRCLE_1} Vali MENÜÜST POKéMON.\n"
	.string "{CIRCLE_2} Vali POKéMON oma selskonnast.\n"
	.string "{CIRCLE_3} Vali KOKKUVÕTE, VAHETA\n"
	.string "   või ESE.$"

Help_Text_HowToUseSummary::
	.string "{CIRCLE_1} Vali KOKKUVÕTE.\n"
	.string "{CIRCLE_2} Vajuta {PLUS} juhtkangil vasakule\n"
	.string "   või paremale teabe kontrollimiseks:\n"
	.string "   POKéMONi INFO\n"
	.string "   POKéMONi OSKUSED\n"
	.string "   TEADAOLEVAD LIIGUTUSED$"

Help_Text_HowToUseSwitch::
	.string "{CIRCLE_1} Vali POKéMON, keda soovid\n"
	.string "   ümber vahetada.\n"
	.string "{CIRCLE_2} Vali VAHETA.\n"
	.string "{CIRCLE_3} Vali POKéMON, kellega esimene\n"
	.string "   vahetada.\n"
	.string "Ekraani vasakul olev POKéMON\n"
	.string "läheb lahingusse esimesena.$"

Help_Text_HowToUseItem::
	.string "{CIRCLE_1} Vali ESE.\n"
	.string "{CIRCLE_2} Vali, kas soovid ANDA eseme\n"
	.string "   POKéMONile hoidmiseks,\n"
	.string "   või VÕTTA ese, mida ta hoiab.\n"
	.string "POKéMON ei saa hoida rohkem\n"
	.string "kui ühte eset!$"

Help_Text_HowToUseBag::
	.string "{CIRCLE_1} Vali MENÜÜST KOTT.\n"
	.string "{CIRCLE_2} Vajuta {PLUS} juhtkangil vasakule\n"
	.string "   või paremale, et kontrollida kategooriaid:\n"
	.string "   ESEMED\n"
	.string "   VÕTMEESEMED\n"
	.string "   POKéPALLID\n"
	.string "   Vajuta üles või alla, et valida ese.$"

Help_Text_HowToUseAnItem::
	.string "{CIRCLE_1} Vali ESEMETE tasku.\n"
	.string "{CIRCLE_2} Vajuta {PLUS} juhtkangil üles\n"
	.string "   või alla, et valida ese.\n"
	.string "{CIRCLE_3} Vali KASUTA, et valitud\n"
	.string "   eset kasutada.\n"
	.string "Mõnda eset ei saa kasutada sõltuvalt\n"
	.string "kohast ja/või olukorrast.$"

Help_Text_HowToUseKeyItem::
	.string "{CIRCLE_1} Vali VÕTMEESEMETE tasku.\n"
	.string "{CIRCLE_2} Vajuta {PLUS} juhtkangil üles\n"
	.string "   või alla, et valida võtmese.\n"
	.string "{CIRCLE_3} Vali KASUTA, et valitud\n"
	.string "   võtmeset kasutada.$"

Help_Text_HowToUsePokeBall::
	.string "{CIRCLE_1} Metsiku POKéMONiga võideldes\n"
	.string "   vali KOTI POKéPALLIDE tasku.\n"
	.string "{CIRCLE_2} Vajuta {PLUS} juhtkangil üles\n"
	.string "   või alla, et valida POKéPALL.\n"
	.string "{CIRCLE_3} Vali KASUTA, et valitud\n"
	.string "   POKéPALL visata.$"

Help_Text_HowToUsePlayer::
	.string "{CIRCLE_1} Vali MENÜÜST {PLAYER}.\n"
	.string "{CIRCLE_2} Sinu TREENIJA KAART kuvatakse\n"
	.string "   esiküljega üles koos põhiteabega.\n"
	.string "   Vajuta A, et kaarti ümber keerata.\n"
	.string "{CIRCLE_3} Kaardi tagaküljel leidub\n"
	.string "   mitmesuguseid andmeid.$"

Help_Text_HowToUseSave::
	.string "{CIRCLE_1} Vali MENÜÜST SALVESTA.\n"
	.string "{CIRCLE_2} Vali JAH ja su edenemine\n"
	.string "   salvestatakse salvestusfaili.\n"
	.string "Pärast salvestamist võid mängu välja\n"
	.string "lülitada. Mängu saab jätkata\n"
	.string "sealt, kus salvestasid.$"

Help_Text_HowToUseOption::
	.string "{CIRCLE_1} Vali MENÜÜST SÄTTED.\n"
	.string "{CIRCLE_2} Vajuta {PLUS} juhtkangil üles\n"
	.string "   või alla, et valida säte, seejärel\n"
	.string "   vajuta vasakule või paremale\n"
	.string "   seadistuste muutmiseks.\n"
	.string "{CIRCLE_3} Vali TÜHISTA või vajuta\n"
	.string "   muudatuste tegemise järel B.$"

Help_Text_HowToUsePotion::
	.string "{CIRCLE_1} Ava MENÜÜ.\n"
	.string "{CIRCLE_2} Vajuta {PLUS} juhtkangil üles\n"
	.string "   või alla ja vali KOTT.\n"
	.string "{CIRCLE_3} Vali ESEMETE taskust ELIKSIIR.\n"
	.string "{CIRCLE_4} Vali KASUTA.\n"
	.string "{CIRCLE_5} Vali POKéMON, keda ravida.$"

Help_Text_HowToUseTownMap::
	.string "{CIRCLE_1} Ava MENÜÜ.\n"
	.string "{CIRCLE_2} Vajuta {PLUS} juhtkangil üles\n"
	.string "   või alla ja vali KOTT.\n"
	.string "{CIRCLE_3} Vajuta vasakule või paremale,\n"
	.string "   et avada VÕTMEESEMETE tasku,\n"
	.string "   seejärel vajuta üles või alla,\n"
	.string "   et valida LINNAKAART.\n"
	.string "{CIRCLE_4} Vali KASUTA, et avada LINNAKAART.$"

Help_Text_HowToUseTM::
	.string "{CIRCLE_1} Ava MENÜÜ.\n"
	.string "{CIRCLE_2} Ava KOTI VÕTMEESEMETE tasku.\n"
	.string "{CIRCLE_3} AVA TM-i KARP.\n"
	.string "{CIRCLE_4} Vali TM ja KASUTA seda.\n"
	.string "{CIRCLE_5} Vali POKéMON, kes suudab selles\n"
	.string "   TM-is oleva liigutuse selgeks õppida.$"

Help_Text_HowToUseHM::
	.string "{CIRCLE_1} Ava MENÜÜ.\n"
	.string "{CIRCLE_2} Ava KOTI VÕTMEESEMETE tasku.\n"
	.string "{CIRCLE_3} AVA TM-i KARP.\n"
	.string "{CIRCLE_4} Vali HM ja KASUTA seda.\n"
	.string "{CIRCLE_5} Vali POKéMON, kes suudab selle selgeks õppida.\n"
	.string "HM-e on raske eemaldada - ole ettevaatlik!$"

Help_Text_HowToUseMoveOutsideOfBattle::
	.string "{CIRCLE_1} Ava MENÜÜ.\n"
	.string "{CIRCLE_2} Vali POKéMON.\n"
	.string "{CIRCLE_3} Vali POKéMON, kes teab\n"
	.string "   HM-i liigutust. Kasutatavad\n"
	.string "   HM-i liigutused kuvatakse siniselt.\n"
	.string "   Vali ja kasuta soovitud liigutust,\n"
	.string "   et takistus hävitada, lennata, surfata jne.$"

Help_Text_HowToRideBicycle::
	.string "{CIRCLE_1} Ava MENÜÜ. Ava KOTI\n"
	.string "   VÕTMEESEMETE tasku\n"
	.string "   ja vali JALGRATAS.\n"
	.string "{CIRCLE_2} JALGRATTAGA saab sõita\n"
	.string "   valides KASUTA. Samuti saad\n"
	.string "   selle koheseks kasutamiseks\n"
	.string "   vajutades SELECT REGISTREERIDA.$"

Help_Text_HowToEnterName::
	.string "{CIRCLE_1} Liiguta kursor soovitud tähele\n"
	.string "   {PLUS} juhtkangiga, seejärel vajuta\n"
	.string "   selle sisestamiseks A.\n"
	.string "{CIRCLE_2} Vajuta B, et samm tagasi minna.\n"
	.string "{CIRCLE_3} Vajuta SELECT, et lülituda\n"
	.string "   suur- ja väiketähtede vahel.\n"
	.string "{CIRCLE_4} Vajuta A nupul OK.$"

Help_Text_HowToUsePC::
	.string "{CIRCLE_1} Mine mõnda POKéMONi KESKUSESSE,\n"
	.string "   mine arvuti juurde ja vajuta A.$"

Help_Text_HowToUseBillsPC::
	.string "{CIRCLE_1} Vali arvutis {STR_VAR_1} ARVUTI.\n"
	.string "{CIRCLE_2} Vali kolmest ülemisest\n"
	.string "   MENÜÜ-kirjest, et pääseda\n"
	.string "   POKéMONide hoiustamissüsteemi.\n"
	.string "Kui püüad POKéMONi, kui sul on\n"
	.string "kuus seltskonnas, saadetakse POKéMON\n"
	.string "automaatselt süsteemi KASTI!$"

Help_Text_HowToUseWithdraw::
	.string "{CIRCLE_1} Vali {PLUS} juhtkangiga\n"
	.string "   avatud KASTIS POKéMON.\n"
	.string "{CIRCLE_2} Vali VÕTA VÄLJA, et POKéMON\n"
	.string "   KASTIST eemaldada ja oma\n"
	.string "   seltskonda lisada.\n"
	.string "POKéMONi ei saa välja võtta,\n"
	.string "kui sul on juba kuus POKéMONi!$"

Help_Text_HowToUseDeposit::
	.string "{CIRCLE_1} Vali {PLUS} juhtkangiga\n"
	.string "   POKéMON oma selskonnast.\n"
	.string "{CIRCLE_2} Vali HOIUSTA.\n"
	.string "{CIRCLE_3} Vali KAST, seejärel vajuta A,\n"
	.string "   et POKéMON salvestada.\n"
	.string "Kui sul on ainult üks POKéMON,\n"
	.string "ei saa teda salvestada!$"

Help_Text_HowToUseMove::
	.string "{CIRCLE_1} Vali avatud KASTIS POKéMON.\n"
	.string "{CIRCLE_2} Tõsta POKéMON üles valides\n"
	.string "   LIIGUTA ja liiguta teda kuhu\n"
	.string "   soovid {PLUS} juhtkangiga.\n"
	.string "{CIRCLE_3} Liiguta POKéMON KASTI nime\n"
	.string "   juurde ja vajuta vasakule või\n"
	.string "   paremale, et teise KASTI liikuda.$"

Help_Text_HowToMoveItems::
	.string "{CIRCLE_1} Hämaralt nähtavaid POKéMONe\n"
	.string "   saab panna eset hoidma, valides\n"
	.string "   POKéMONi ja vajutades A.\n"
	.string "{CIRCLE_2} Selgelt nähtavaid POKéMONe\n"
	.string "   saab panna nende hoitava eseme\n"
	.string "   teisele POKéMONile andma või\n"
	.string "   KOTTI tagastama A-nupuga.$"

Help_Text_HowToUsePlayersPC::
	.string "{CIRCLE_1} Vali arvutis {PLAYER} ARVUTI.\n"
	.string "{CIRCLE_2} Vali kas ESEMETE HOIUSTAMINE\n"
	.string "   või POSTKAST.\n"
	.string "Oma arvutisse saad asju hoiustada,\n"
	.string "kui su KOTT on täis. Samuti saad\n"
	.string "oma arvutis hoiustatud esemeid välja võtta.$"

Help_Text_HowToUseWithdrawItem::
	.string "{CIRCLE_1} Vali VÕTA ESE VÄLJA.\n"
	.string "{CIRCLE_2} Vali ese, mida välja võtta.\n"
	.string "{CIRCLE_3} Ese saab välja võetud ja\n"
	.string "   paigutatud KOTI ESEMETE taskusse.\n"
	.string "   Seda saab ka otse anda\n"
	.string "   POKéMONile hoidmiseks.$"

Help_Text_HowToUseDepositItem::
	.string "{CIRCLE_1} Vali HOIUSTA ESE.\n"
	.string "{CIRCLE_2} Vali {PLUS} juhtkangiga KOTIS\n"
	.string "   olev ese, mida hoiustada.\n"
	.string "{CIRCLE_3} Kui hoiustatavaid esemeid\n"
	.string "   on rohkem kui üks, sisesta\n"
	.string "   kogus {PLUS} juhtkangiga,\n"
	.string "   seejärel vajuta A.$"

Help_Text_HowToUseMailbox::
	.string "Kui POKéMONilt võetakse KIRI,\n"
	.string "viiakse see POSTKASTI. Kui tal pole\n"
	.string "KIRJA, ei saa POSTKASTI kasutada.\n"
	.string "{CIRCLE_1} Vali arvutis {PLAYER} ARVUTI.\n"
	.string "{CIRCLE_2} Vali POSTKAST, et KIRJU lugeda\n"
	.string "   või POKéMONil KIRI kaasas olla.$"

Help_Text_HowToUseProfOaksPC::
	.string "{CIRCLE_1} Vali arvutis PROF. TAMME ARVUTI.\n"
	.string "{CIRCLE_2} PROF. TAMM hindab sinu\n"
	.string "   POKéDEXit.\n"
	.string "Tema hinnangud peaksid andma vihjeid\n"
	.string "rohkemate POKéMONide püüdmiseks!$"

Help_Text_HowToOpenMenu::
	.string "{CIRCLE_1} Vajuta START.\n"
	.string "{CIRCLE_2} MENÜÜ avaneb paremal.\n"
	.string "{CIRCLE_3} Sõltuvalt olukorrast võib MENÜÜS\n"
	.string "   olla erinevaid rubriike.\n"
	.string "MENÜÜ ei avane teatud\n"
	.string "olukordades, näiteks rääkides,\n"
	.string "midagi tehes, lahingus jne.$"

Help_Text_HowToUseFight::
	.string "{CIRCLE_1} Vali VÕITLE.\n"
	.string "{CIRCLE_2} Vali üks näidatud liigutustest\n"
	.string "ja seda liigutust kasutatakse!$"

Help_Text_HowToUsePokemon2::
	.string "{CIRCLE_1} Vali POKéMON.\n"
	.string "{CIRCLE_2} Vali POKéMON oma selskonnast,\n"
	.string "   keda soovid kasutada.\n"
	.string "{CIRCLE_3} Kui sul on kaks või rohkem\n"
	.string "   POKéMONi, saab neid vahetada\n"
	.string "   valides VAHETA. Kontrolli\n"
	.string "   andmeid valides KOKKUVÕTE.$"

Help_Text_HowToUseShift::
	.string "See käsk vahetab lahingus oleva\n"
	.string "POKéMONi teise vastu sinu selskonnast.\n"
	.string "{CIRCLE_1} Vali POKéMON, keda saata välja.\n"
	.string "{CIRCLE_2} Vali VAHETA.\n"
	.string "{CIRCLE_3} Valitud POKéMON vahetab kohad\n"
	.string "   lahingus oleva POKéMONiga!$"

Help_Text_HowToUseSummary2::
	.string "{CIRCLE_1} Vali KOKKUVÕTE.\n"
	.string "{CIRCLE_2} Vajuta {PLUS} juhtkangil vasakule\n"
	.string "   või paremale, et kontrollida teavet:\n"
	.string "   POKéMONi INFO\n"
	.string "   POKéMONi OSKUSED\n"
	.string "   TEADAOLEVAD LIIGUTUSED$"

Help_Text_HowToUseBag2::
	.string "{CIRCLE_1} Vali KOTT.\n"
	.string "{CIRCLE_2} Vajuta {PLUS} juhtkangil vasakule\n"
	.string "   või paremale, et kontrollida kategooriaid:\n"
	.string "   ESEMED\n"
	.string "   VÕTMEESEMED\n"
	.string "   POKéPALLID\n"
	.string "   Vajuta üles või alla, et valida ese.$"

Help_Text_HowToReadPokedex::
	.string "{CIRCLE_1} POKéMONid, keda oled püüdnud,\n"
	.string "   tähistatakse POKéPALLI märgiga\n"
	.string "   POKéDEXi nimekirjas.\n"
	.string "{CIRCLE_2} Püütud POKéMON annab\n"
	.string "   suure hulga andmeid.\n"
	.if REVISION < 1
	.string "{CIRCLE_3} Vali ALA, et kuvada LINNAKAART\n"
