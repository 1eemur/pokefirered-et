Help_Text_AnswerPlayingForFirstTime::
	.string "Sa saad peategelaseks,\n"
	.string "uurides POKéMONi maailma.\l"
	.string "Inimestega rääkides ja mõistatusi\l"
	.string "lahendades avanevad sulle uued teed.\l"
	.string "Püüdle eesmärgi poole koos oma\l"
	.string "suurepäraste POKéMONidega.$"

Help_Text_AnswerWhatShouldIBeDoing::
	.string "Kui kohtad teist inimest, mine tema\n"
	.string "juurde ja vajuta nuppu A.\l"
	.string "See paneb ta rääkima ja suhtlema\l"
	.string "sinu tegelasega. Samuti saad\l"
	.string "erinevaid esemeid ja objekte\l"
	.string "samal viisil uurida. Räägi inimestega\l"
	.string "ja kontrolli asju sageli.$"

Help_Text_AnswerCantGetOutOfRoom::
	.string "Trepil või hoone väljapääsul on\n"
	.string "punane matt. Liiguta oma tegelane\l"
	.string "punase mati peale seisma.\l"
	.string "Vajuta {PLUS} juhtkangil treppide\l"
	.string "või väljapääsu suunas,\l"
	.string "et edasi liikuda.$"

Help_Text_AnswerCantFindPersonIWant::
	.string "See pole midagi, mille pärast\n"
	.string "liiga palju muretseda.\l"
	.string "Räägi teiste inimestega, kontrolli\l"
	.string "silte, uuri asju jne.\l"
	.string "Mõnikord võib olla vaja lihtsalt\l"
	.string "liikuda uude linna või kohta.$"

Help_Text_AnswerTalkedToEveryoneNowWhat::
	.string "Proovi liikuda edasi uuele teele,\n"
	.string "linna või kohta.$"

Help_Text_AnswerSomeoneBlockingMyWay::
	.string "Linnas või hoone sees võib olla\n"
	.string "midagi, mis selle põhjustab.\l"
	.string "Proovi piirkonna inimestega\l"
	.string "uuesti rääkida. Kui neil on lahendamist\l"
	.string "vajav probleem, võid pead aidata.\l"
	.string "Seejärel proovi uuesti rääkida\l"
	.string "sinul teed tõkestava isikuga.$"

Help_Text_AnswerICantGoOn::
	.string "Proovi rääkida inimestega, minnes\n"
	.string "nende juurde ja vajutades nuppu A.\l"
	.string "Samuti proovi uurida kummalisi puid\l"
	.string "ja veidraid kive nupuga A.\l"
	.string "Vajuta {PLUS} juhtkangil ja proovi minna\l"
	.string "ka kohtadesse, mis näivad läbimatud.$"

Help_Text_AnswerOutOfThingsToDo::
	.string "Proovi minna kohtadesse, kus sa\n"
	.string "pole veel käinud.\l"
	.string "Samuti kontrolli kõike, mis tundub\l"
	.string "kahtlane, vajutades nuppu A.$"

Help_Text_AnswerWhatHappenedToItemIGot::
	.string "Iga ese, mille sulle teine tegelane\n"
	.string "annab, läheb su KOTTI.\l"
	.string "Ese sorteeritakse automaatselt\l"
	.string "ja paigutatakse ühte kolmest taskust.\l"
	.string "Koti kasutamise juhiste saamiseks\l"
	.string "vaata ABIsüsteemi rubriiki\l"
	.string "Kuidas seda teha?.$"

Help_Text_AnswerWhatAreMyAdventureBasics::
	.string "Kui POKéMONid saavad lahingus vigastada,\n"
	.string "vii nad POKéMONi KESKUSESSE ja\l"
	.string "lase personal neid ravida.\l"
	.string "Harju mängu salvestama ja\l"
	.string "edu kirja panema.\l"
	.string "Varusta end ravimiainetega\l"
	.string "POKéMONi POODIDEST enne kaugemat reisi.$"

Help_Text_AnswerHowAreRoadsForestsDifferent::
	.string "Metsad on põhimõtteliselt samad\n"
	.string "mis teed, kuid võivad olla labürindid.\l"
	.string "Kõigist metsadest pääseb välja,\l"
	.string "seega ära anna alla, kui eksid.$"

Help_Text_AnswerHowAreCavesDifferent::
	.string "Koobad on pimedad ja ohtlikud.\n"
	.string "Metsikud POKéMONid võivad ilmuda igal pool.\l"
	.string "Hädaolukorras kiirusta\l"
	.string "POKéMONi KESKUSESSE või kasuta esemeid.\l"
	.string "Mõne kooopa taga ootavad avastamist\l"
	.string "uued linnad, seega ära anna alla.$"

Help_Text_AnswerHowDoIProgress::
	.string "Mängu eesmärk on treenida oma\n"
	.string "POKéMONe ja edasi liikuda.\l"
	.string "Pead koguma infot ja lahendama\l"
	.string "probleeme. Näiteks, mida vajad\l"
	.string "takistusest mööda saamiseks?\l"
	.string "Mis saaks selle tõkestava\l"
	.string "isiku teelt kõrvale saata?$"

Help_Text_AnswerWhenCanIUseItem::
	.string "Esemeid on mitut liiki.\n"
	.string "Mõnda saab kasutada ainult väljas.\l"
	.string "Mõned on ainult lahingus kasutamiseks.\l"
	.string "Mõnda saab kasutada igal ajal.\l"
	.string "Proovi eset kasutada - kui seda ei saa\l"
	.string "kasutada, saad vastava teate.$"

Help_Text_AnswerWhatsABattle::
	.string "Lahingus püüavad POKéMONid vähendada\n"
	.string "teineteise elujõudu, mida väljendatakse\l"
	.string "ELuna. Kui POKéMONi EL langeb nullini,\l"
	.string "minestub ta ning teine POKéMON\l"
	.string "võidab. Lahingu võites teenivad\l"
	.string "POKéMONid KOGEMUSEpunkte, mis\l"
	.string "aitavad neil tasemeid tõusta.$"

Help_Text_AnswerHowDoIPrepareForBattle::
	.string "Kõigepealt ravitse oma seltskonna\n"
	.string "POKéMONid täielikult (POKéMONid,\l"
	.string "kes on sinuga) mõnes\l"
	.string "POKéMONi KESKUSES.\l"
	.string "Osta ka ravimiained hädaolukordadeks\l"
	.string "POKéMONi POEST.$"

Help_Text_AnswerWhatIsAMonsVitality::
	.string "POKéMONi elujõudu väljendatakse ELina.\n"
	.string "Kui POKéMON saab lahingus vigastada, EL\l"
	.string "väheneb. Kui EL langeb nullini,\l"
	.string "minestub POKéMON.\l"
	.string "Ravi vigastatud ja minestunud POKéMONid\l"
	.string "POKéMONi KESKUSES või esemete abil.$"

Help_Text_AnswerMyMonsAreHurt::
	.string "POKéMONi KESKUS on nagu võõrastemaja\n"
	.string "POKéMONidele. See ravib POKéMONe\l"
	.string "täielikult kõigist staatusprobleemidest\l"
	.string "ja taastab nende ELi erilise masina abil.\l"
	.string "See teenus on tasuta, seega harju\l"
	.string "oma POKéMONe sageli ravimas käima.$"

Help_Text_AnswerWhatIsStatusProblem::
	.string "Staatusprobleem viitab vaevusele,\n"
	.string "mille vaenlase rünnak POKéMONile\l"
	.string "põhjustab. Nende hulka kuuluvad\l"
	.string "põletused, halvatus, mürgistus,\l"
	.string "uni ja külmutamine. Neid saab ravida\l"
	.string "külastades POKéMONi KESKUST või\l"
	.string "kasutades sobivat eset.$"

Help_Text_AnswerWhatHappensIfAllMyMonsFaint::
	.string "Kui kõik sinu seltskonna POKéMONid\n"
	.string "(kõik sinuga olevad POKéMONid) minestuvad,\l"
	.string "kaotad osa RAHAST ning sind\l"
	.string "viiakse koju või POKéMONi\l"
	.string "KESKUSESSE. Vähenda seda ohtu, külastades\l"
	.string "POKéMONi KESKUSEID sageli. Samuti\l"
	.string "harju sageli salvestama.$"

Help_Text_AnswerCantCatchMons::
	.string "Kui metsik POKéMON põgeneb POKéPALLIST,\n"
	.string "on ta ilmselgelt veel elujõuline.\l"
	.string "Proovi tema ELi veelgi vähendada\l"
	.string "ning nõrgenda teda halvatuse või unega\l"
	.string "enne püüdmist.\l"
	.string "Kui POKéPALL kaua kõigub,\l"
	.string "on püüdmine peaaegu õnnestunud!$"

Help_Text_AnswerRanOutOfPotions::
	.string "On olemas poed, mida tuntakse\n"
	.string "POKéMONi POODIDENA, kus müüakse esemeid.\l"
	.string "POKéMONi POODE ei leidu\l"
	.string "teedel, metsades ega koobaste.\l"
	.string "Varusta end vajalike esemetega,\l"
	.string "kui külastad linna POKéMONi POEGA.$"

Help_Text_AnswerCanIBuyPokeBalls::
	.string "POKéPALLE saab osta igast\n"
	.string "POKéMONi POEST igas linnas.\l"
	.string "POKéMONi POODE ei leidu\l"
	.string "teedel, metsades ega koobaste.\l"
	.string "Varusta end POKéPALLIDEGA,\l"
	.string "kui külastad linna POKéMONi POEGA.$"

Help_Text_AnswerWhatsATrainer::
	.string "TREENIJA on inimene, kes kasvatab\n"
	.string "POKéMONe lahingute kaudu.\l"
	.string "TREENIJAD väljakutsuvad sind\l"
	.string "kus iganes nad on - teel,\l"
	.string "metsades, koopastes, kõikjal.\l"
	.string "Kui teie silmad kohtuvad, pead\l"
	.string "nende väljakutse vastu võtma. Ole ettevaatlik!$"

Help_Text_AnswerHowDoIWinAgainstTrainer::
	.string "TREENIJA lahingus võitmiseks kasuta\n"
	.string "POKéMONe, kellel on tüübieelised\l"
	.string "vaenlase POKéMONide üle. Võid kasutada\l"
	.string "ka hästi treenitud POKéMONe\l"
	.string "ülivõimsa jõuga. Vaenlase POKéMONide\l"
	.string "arvuline ülekaal on samuti\l"
	.string "ilmne taktika.$"

Help_Text_AnswerWhereDoMonsAppear::
	.string "Metsikud POKéMONid ilmuvad pikas rohus,\n"
	.string "teedel ja metsades. Nad ilmuvad\l"
	.string "kõikjal pimeda koopa sees.\l"
	.string "Linnades pole metsikuid POKéMONe ega\l"
	.string "TREENIJAID, seega on need turvalised kohad.$"

Help_Text_AnswerWhatAreMoves::
	.string "POKéMONid võivad õppida kuni neli erinevat\n"
	.string "tehnikat ehk liigutust. On suur\l"
	.string "valik liigutusi, sealhulgas rünnakuid ja\l"
	.string "erimõjuga liigutusi. Õpitavate liigutuste\l"
	.string "liigid erinevad iga POKéMONi puhul.\l"
	.string "Mõnda liigutust saab masinatelt õppida.$"

Help_Text_AnswerWhatAreHiddenMoves::
	.string "PEIDETUD liigutused on eriti olulised\n"
	.string "su seiklusele. Sellise liigutuse\l"
	.string "kasutamiseks väljaspool lahingut ava\l"
	.string "POKéMONi MENÜÜ ja lase seda liigutust\l"
	.string "tundval POKéMONil seda kasutada.\l"
	.string "Minestunud POKéMON võib kasutada\l"
	.string "PEIDETUD liigutust väljaspool lahingut.$"

Help_Text_AnswerWhatMovesShouldIUse::
	.string "Vali VÕITLE ja ilmub liigutuste MENÜÜ.\n"
	.string "Kaalu tüübikombinatsioone ning kasuta\l"
	.string "kõige tõhusamaid liigutusi. Saad\l"
	.string "liigutuste mõjusid kontrollida avades\l"
	.string "POKéMON, valides POKéMONi, avades\l"
	.string "KOKKUVÕTE ning seejärel\l"
	.string "POKéMONi OSKUSED.$"

Help_Text_AnswerWantToAddMoreMoves::
	.string "POKéMON saab õppida maksimaalselt neli\n"
	.string "liigutust. Need õpitakse selgeks, kui\l"
	.string "POKéMON tasemeid tõuseb. Samuti saab\l"
	.string "talle liigutust õpetada TM-i (Tehniline\l"
	.string "Masin) või HM-i (Peidetud Masin) abil.\l"
	.string "On ka inimesi, kes liigutusi õpetavad.$"

Help_Text_AnswerWantToMakeMonStronger::
	.string "Võti oma POKéMONide tugevamaks tegemiseks\n"
	.string "on sageli lahinguid pidada ja võita.\l"
	.string "Võitudes kogutud KOGEMUSE punktid\l"
	.string "kogunevad, et tõsta lahingus osalenud\l"
	.string "POKéMONide taset. Võitle sageli\l"
	.string "metsikute POKéMONidega, et\l"
	.string "oma seltskonda tasemeid tõsta.$"

Help_Text_AnswerFoeMonsTooStrong::
	.string "Kui vaenlased on liiga tugevad, proovi\n"
	.string "oma POKéMONide taset veelgi tõsta.\l"
	.string "Mine tagasi tulnud teed ja võitle\l"
	.string "metsikute POKéMONidega oma seltskonna\l"
	.string "taseme tõstmiseks. Võid ka võidelda\l"
	.string "TREENIJATEGA, kellega pole veel\l"
	.string "lahingut pidanud.$"

Help_Text_AnswerWhatDoIDoInCave::
	.string "Erinevalt teedest ja metsadest võivad\n"
	.string "koopastes metsikud POKéMONid ilmuda igal pool.\l"
	.string "Kui su POKéMONid saavad koopas vigastada,\l"
	.string "kiirusta POKéMONi KESKUSESSE või kasuta\l"
	.string "nende ravimiseks kohe esemeid.\l"
	.string "Koopastes õnne kiusamine on väga ohtlik.$"

Help_Text_AnswerNothingIWantToKnow::
	.string "Usalda oma teadmisi ja jõudu.\n"
	.string "Usu endasse ja leia oma tee!$"

Help_Text_AnswerWhatsPokemonCenter::
	.string "POKéMONi KESKUST tunneb ära punase katuse\n"
	.string "ja P.K sildi järgi. Iga\l"
	.string "POKéMONi KESKUS pakub selliseid teenuseid\l"
	.string "nagu POKéMONide täielik ravimine ja tasuta\l"
	.string "arvuti kasutamine - see on su reisidel\l"
	.string "hädavajalik. Ülakorrusel on\l"
	.string "sõpradega ühenduse loomise rajatised.$"

Help_Text_AnswerWhatsPokemonMart::
	.string "POKéMONi POODI tunneb ära sinise katuse\n"
	.string "ja POOD sildi järgi.\l"
	.string "Esemeid saab osta ja müüa igast\l"
	.string "POKéMONi POEST. Mõned POED pakuvad\l"
	.string "esemeid, mis on saadaval ainult nende linnas.$"

Help_Text_AnswerWantToEndGame::
	.string "Saad mängu turvaliselt lõpetada\n"
	.string "valides MENÜÜST SALVESTA.\l"
	.string "Pärast salvestamist saab mängu\l"
	.string "turvaliselt välja lülitada. Mängu\l"
	.string "uuesti käivitades saad jätkata\l"
	.string "sealt, kus viimati salvestasid.$"

Help_Text_AnswerWhatsAMon::
	.string "POKéMONid on elusolendid, kelle kohta\n"
	.string "on palju mõistatusi lahendamata. Neid\l"
	.string "võib näha rohus, meres ja koopastes.\l"
	.string "Nad näivad kuuletuvat neid\l"
	.string "püüdnud TREENIJATE soovidele.$"

Help_Text_AnswerWhatIsThatPersonLike::
	.string "Kasuta KUULSUSEKONTROLLIJAT\n"
	.string "oma KOTI VÕTMEESEMETE hulgas.\l"
	.string "See võib anda vihjeid - proovi järele.$"

Help_Text_AnswerWhatDoesHiddenMoveDo::
	.string "PEIDETUD liigutust õpetatakse POKéMONile\n"
	.string "HM-i (Peidetud Masina) abil.\l"
	.string "PEIDETUD liigutus on seiklusel\l"
	.string "oluline abi. Näiteks ühega saab\l"
	.string "pimedad koobad valgustada. Teine\l"
	.string "lõikab väikseid puid. On ka üks,\l"
	.string "millega veepinnal liikuda, ja nii edasi.$"

Help_Text_AnswerWhatDoIDoInSafari::
	.string "Proovi metsikuid POKéMONe püüda\n"
	.string "visates erilisi SAFARIPALLE.\l"
	.string "Võid ka leitud esemeid endale jätta.$"

Help_Text_AnswerWhatAreSafariRules::
	.string "Sinu SAFARIMÄNG lõpeb, kui oled\n"
	.string "teatud vahemaa läbinud või kõik\l"
	.string "SAFARIPALLID visanud.\l"
	.string "Ava MENÜÜ, et kontrollida\l"
	.string "järelejäänud sammude arvu ja SAFARIPALLE.$"

