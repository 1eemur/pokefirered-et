Help_Text_DescTheHelpSystem::
	.string "Abiinfo muutub vastavalt sellele,\n"
	.string "kui kaugele oled mängus jõudnud.\l"
	.string "Need on loodud sind toetama,\l"
	.string "kui neid vajad. Kui on midagi,\l"
	.string "mida ei mõista, otsi üles ABIsüsteem!$"

Help_Text_DescTheGame::
	.string "Sa saad peategelaseks, et\n"
	.string "uurida POKéMONi maailma!\l"
	.string "Inimestega rääkides ja mõistatusi\l"
	.string "lahendades avanevad sulle uued teed.\l"
	.string "Püüdle eesmärgi poole koos oma\l"
	.string "suurepäraste POKéMONidega!$"

Help_Text_DescWirelessAdapter::
	.string "See mäng suhtleb juhtmevaba\n"
	.string "ühenduse kaudu juhtmevaba adapteriga.\p"
	.string "Ole juhtmevaba igal ajal, igal pool\n"
	.string "ja kõigiga!\p"
	.string "Proovi mängida juhtmevaba adapteriga\n"
	.string "alati ühendatuna!$"

Help_Text_DescGameFundamentals1::
	.string "Külasta iga linna ja alevit, läbi\n"
	.string "iga tee, uuri iga koobast ja\l"
	.string "võta iga väljakutse vastu,\l"
	.string "et pürgida suurimaks POKéMONide\l"
	.string "TREENIJAKS!$"

Help_Text_DescGameFundamentals2::
	.string "Oma seiklusel seisad silmitsi\n"
	.string "paljude takistustega. Iga takistuse\l"
	.string "saab ületada midagi tehes\l"
	.string "või mõistatusi lahendades. Mõnda\l"
	.string "takistust mõjutab miski, mis juhtub\l"
	.string "kaugel.$"

Help_Text_DescGameFundamentals3::
	.string "Mõned su teel olevad takistused\n"
	.string "saab eemaldada, kui su POKéMONid\l"
	.string "õpivad selgeks kindlad liigutused.$"

Help_Text_DescWhatArePokemon::
	.string "POKéMONid on imelised olendid,\n"
	.string "kes on mõistatuste hõlmas. Neid võid\l"
	.string "kohata kõikjal maailmas… pikas\l"
	.string "rohus, koopastes, meres ja mujal.\l"
	.string "Nad näivad kasvavat kuulekaks\l"
	.string "neid püüdnud TREENIJATELE.$"

