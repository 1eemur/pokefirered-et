	.string "sihtmärk-POKéMONi tüübi vastavusest\l"
	.string "varieerub liigutuse tõhusus:\l"
	.string "{CIRCLE_DOT}: Väga tõhus!\l"
	.string "{TRIANGLE}: Mitte eriti tõhus\l"
	.string "{BIG_MULT_X}: Ei mõju üldse\l"
	.string "(Muudel vastavustel muutusi pole.)$"

